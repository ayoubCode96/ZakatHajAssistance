{
  "expo": {
    "name": "ZakatiHajjAssistant",
    "slug": "ZakatiHajjAssistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/IconApp.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "zakati",
    "splash": {
      "image": "./assets/AdIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "automatic",
      "bundleIdentifier": "com.zakati.hajjassistant",
      "icon": "./assets/IconApp.png",
      "associatedDomains": ["applinks:nfddhkvvwslmzzuqkaqg.supabase.co"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/AdIcon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "userInterfaceStyle": "automatic",
      "package": "com.zakati.hajjassistant",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "zakati",
              "host": "*",
              "pathPrefix": "/"
            },
            {
              "scheme": "exp",
              "host": "*",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-web-browser"
    ]
  }
}
